# Midtrans Configuration
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false

# PocketBase Configuration
POCKETBASE_URL=http://127.0.0.1:8090
POCKETBASE_ADMIN_EMAIL=admin@kartara.com
POCKETBASE_ADMIN_PASSWORD=your-admin-password

# Server Configuration
PORT=3000
NODE_ENV=development

# App Configuration
APP_NAME=Kartara
APP_URL=http://localhost:3000
FRONTEND_URL=kartara://payment

# Ngrok Configuration (for webhook testing)
# Run: ngrok http 3000
# Then update this with your ngrok URL
NGROK_URL=https://your-ngrok-url.ngrok.io

# Gemini API Configuration (Google AI Studio)
# Dapatkan API Key gratis di: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Email SMTP Configuration (Untuk OTP registrasi & reset password)
# 1. Jika menggunakan Brevo SMTP:
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-brevo-login-email@domain.com
# SMTP_PASS=your-brevo-smtp-key (bukan API key)
# SMTP_FROM=your-verified-sender@domain.com
#
# 2. Jika menggunakan Gmail SMTP (Default fallback):
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-gmail-app-password

